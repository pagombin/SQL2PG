# MySQL2PG Configuration
#
# Only the Aiven API credentials are required here.
# Everything else (Kafka service, MySQL sources, PostgreSQL target)
# is configured through the web-based Migration Wizard.

aiven:
  # Aiven API bearer token (retrieve from Aiven console)
  token: "your-aiven-api-token"
  # Aiven project name (e.g., do-user-xxxxxxx-0)
  project: "do-user-xxxxxxx-0"

# ── Optional overrides (only needed for CLI / config-driven path) ──
#
# kafka:
#   service_name: "db-kafka-nyc3-93111"
#   # ssl_host and ssl_port are auto-resolved from the Aiven API if omitted.
#   # ssl_host: "kafka-ssl-hostname"
#   # ssl_port: 25062
#
# mysql_sources:
#   - name: "mysql-source-1"
#     host: "mysql-host.db.ondigitalocean.com"
#     port: 25060
#     username: "doadmin"
#     password: "your-mysql-password"
#     server_id: 1001
#     databases:
#       - name: "inventory"
#
# postgresql_target:
#   host: "pg-host.db.ondigitalocean.com"
#   port: 25060
#   username: "doadmin"
#   password: "your-pg-password"
#   database: "defaultdb"
#
# table_name_strategy: "as_is"
